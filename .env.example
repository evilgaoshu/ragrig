# RAGRig — minimal config for `docker compose up`.
# All values below already work as-is; copy this file to `.env` only if you
# need to override a default.

# Demo mode: skip auth and pre-seed a tiny knowledge base so a fresh
# install is browsable immediately. Set to `true` for production.
RAGRIG_AUTH_ENABLED=false
RAGRIG_DEMO_SEED=1
# APP_ENV=production
# RAGRIG_AUTH_SECRET_PEPPER=replace-with-a-long-random-secret

# Host ports — override only if 8000 / 5432 are taken.
APP_HOST_PORT=8000
DB_HOST_PORT=5432

# Compose resource defaults for the primary app and database containers.
# RAGRIG_APP_MEM_LIMIT=2g
# RAGRIG_APP_CPUS=2.0
# RAGRIG_DB_MEM_LIMIT=2g
# RAGRIG_DB_CPUS=2.0

# PostgreSQL SQLAlchemy pool settings. These are ignored for SQLite test URLs.
# RAGRIG_DB_POOL_SIZE=10
# RAGRIG_DB_MAX_OVERFLOW=20
# RAGRIG_DB_POOL_RECYCLE=1800

# Optional model credentials. The default answer provider is
# `deterministic-local`, which needs no API key. Drop a key here only if
# you wire RAGRIG_ANSWER_PROVIDER to openai/openrouter/gemini in compose.
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=

# Production disables fake reranker fallback by default. Set to `true` only
# for explicitly accepted demos in degraded environments.
# RAGRIG_ALLOW_FAKE_RERANKER=false

# Optional CORS for split frontend/API deployments.
# RAGRIG_CORS_ORIGINS=https://app.example.com,https://admin.example.com
# RAGRIG_CORS_ALLOW_CREDENTIALS=false

# Production observability. Metrics are enabled by default; file logs stay
# opt-in so container platforms can keep collecting stdout/stderr. Set
# RAGRIG_LOG_FILE to /app/logs/ragrig.jsonl when you want compose-managed
# rotating logs persisted in the ragrig_logs volume.
# RAGRIG_METRICS_ENABLED=true
# RAGRIG_METRICS_WORKSPACE_LABELS_ENABLED=false
# RAGRIG_LOG_FORMAT=json
# RAGRIG_LOG_LEVEL=INFO
# RAGRIG_LOG_FILE=/app/logs/ragrig.jsonl
# RAGRIG_LOG_MAX_BYTES=10485760
# RAGRIG_LOG_BACKUP_COUNT=5

# Optional task queue. Threadpool is the default. Switch to ARQ only when a
# Redis service and worker are deployed.
# RAGRIG_TASK_BACKEND=threadpool
# RAGRIG_REDIS_URL=redis://localhost:6379
# RAGRIG_TASK_QUEUE_MAX_JOBS=10

# Optional services (S3/MinIO, fileshare live smoke, Qdrant) — see
# docs/operations/optional-services.md for the full env reference.

# Email / SMTP (for invitation emails). Disabled by default.
# RAGRIG_SMTP_ENABLED=true
# RAGRIG_SMTP_HOST=smtp.example.com
# RAGRIG_SMTP_PORT=587
# RAGRIG_SMTP_USE_TLS=true
# RAGRIG_SMTP_USERNAME=user@example.com
# RAGRIG_SMTP_PASSWORD=secret
# RAGRIG_SMTP_FROM=noreply@example.com
# RAGRIG_APP_BASE_URL=https://yourapp.example.com

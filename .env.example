# RAGRig — minimal config for `docker compose up`.
# All values below already work as-is; copy this file to `.env` only if you
# need to override a default.

# Demo mode: skip auth and pre-seed a tiny knowledge base so a fresh
# install is browsable immediately. Set to `true` for production.
RAGRIG_AUTH_ENABLED=false
RAGRIG_DEMO_SEED=1

# Host ports — override only if 8000 / 5432 are taken.
APP_HOST_PORT=8000
DB_HOST_PORT=5432

# Optional model credentials. The default answer provider is
# `deterministic-local`, which needs no API key. Drop a key here only if
# you wire RAGRIG_ANSWER_PROVIDER to openai/openrouter/gemini in compose.
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=

# Production disables fake reranker fallback by default. Set to `true` only
# for explicitly accepted demos in degraded environments.
# RAGRIG_ALLOW_FAKE_RERANKER=false

# Optional services (S3/MinIO, fileshare live smoke, Qdrant) — see
# docs/operations/optional-services.md for the full env reference.

# Email / SMTP (for invitation emails). Disabled by default.
# RAGRIG_SMTP_ENABLED=true
# RAGRIG_SMTP_HOST=smtp.example.com
# RAGRIG_SMTP_PORT=587
# RAGRIG_SMTP_USE_TLS=true
# RAGRIG_SMTP_USERNAME=user@example.com
# RAGRIG_SMTP_PASSWORD=secret
# RAGRIG_SMTP_FROM=noreply@example.com
# RAGRIG_APP_BASE_URL=https://yourapp.example.com

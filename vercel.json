{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python -m compileall api src scripts",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
